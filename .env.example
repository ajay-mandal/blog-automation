# ── Auth ────────────────────────────────────────────────────────────────────────
# Single-user password gate — change this to a strong passphrase
ADMIN_PASSWORD=change-me-before-running

# ── Encryption ───────────────────────────────────────────────────────────────────
# 32-byte random hex used to AES-256-GCM encrypt stored API keys
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-char-hex-string

# ── App Database (this project's Supabase) ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJyour-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJyour-service-role-key
