# ── Auth ─────────────────────────────────────────────────────────────────────
# Password to log in to the blog automation dashboard
ADMIN_PASSWORD=change-me-before-running

# ── App Database (this project's Supabase) ────────────────────────────────────
# Use the pgbouncer URL for the Prisma query engine (pooled)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres?pgbouncer=true
# Direct URL for Prisma migrations (non-pooled)
DIRECT_URL=postgresql://postgres:password@host:5432/postgres

# Supabase client for the app DB
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your-key
# Service role key — used only server-side for admin DB operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Portfolio Supabase (ajaymandal.com) ───────────────────────────────────────
# Credentials for the PORTFOLIO site's Supabase project (separate from this app's DB)
# Service role key bypasses RLS so blogs can be upserted directly into the posts table
PORTFOLIO_SUPABASE_URL=https://your-portfolio-project.supabase.co
PORTFOLIO_SUPABASE_SERVICE_ROLE_KEY=your-portfolio-service-role-key

# ── AI Provider API Keys ──────────────────────────────────────────────────────
# Add only the providers you intend to use — unused ones can be left blank

# OpenAI — used for GPT-4o / GPT-4.1 and DALL-E 3 image generation
OPENAI_API_KEY=

# Anthropic — used for Claude models
ANTHROPIC_API_KEY=

# Google AI — used for Gemini models
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Image Search APIs ─────────────────────────────────────────────────────────
# Unsplash — for searching free stock photos (server-side proxy, key never exposed to client)
UNSPLASH_ACCESS_KEY=

# Pexels — alternative stock photo source
PEXELS_API_KEY=
